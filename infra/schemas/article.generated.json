{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "article.generated",
  "type": "object",
  "required": ["event_id", "trace_id", "article_id", "market", "language", "content", "topic_id", "timestamp", "title", "excerpt", "section", "author", "tags", "slug"],
  "properties": {
    "event_id":   {"type": "string", "format": "uuid"},
    "trace_id":   {"type": "string"},
    "article_id": {"type": "string", "format": "uuid"},
    "market":     {"type": "string", "enum": ["italy", "usa", "china"]},
    "language":   {"type": "string", "enum": ["it", "en", "zh"]},
    "content":    {"type": "string", "description": "Full article body"},
    "title":      {"type": "string", "maxLength": 200},
    "excerpt":    {"type": "string", "maxLength": 400},
    "section":    {"type": "string", "enum": ["degustazioni","cantine","itinerari","territori","abbinamenti","eventi","interviste","guida","sostenibilita"]},
    "author":     {"type": "string", "maxLength": 120},
    "tags":       {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 8},
    "slug":       {"type": "string", "maxLength": 100, "pattern": "^[a-z0-9-]+$"},
    "topic_id":   {"type": "string", "format": "uuid"},
    "quality_score": {"type": "number"},
    "timestamp":  {"type": "string", "format": "date-time"},
    "usage": {
      "type": "object",
      "description": "Per-call LLM token + cost data, populated by agent at generation time (Phase K1). Optional for back-compat.",
      "properties": {
        "prompt_tokens":     {"type": "integer", "minimum": 0},
        "completion_tokens": {"type": "integer", "minimum": 0},
        "model":             {"type": "string"},
        "cost_usd":          {"type": "number",  "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
