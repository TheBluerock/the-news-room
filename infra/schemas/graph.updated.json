{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "graph.updated",
  "type": "object",
  "required": ["event_id", "trace_id", "market", "updated_entities", "timestamp"],
  "properties": {
    "event_id":         {"type": "string", "format": "uuid"},
    "trace_id":         {"type": "string"},
    "market":           {"type": "string", "enum": ["italy", "usa", "china"]},
    "updated_entities": {"type": "array", "items": {"type": "string", "format": "uuid"}},
    "timestamp":        {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
