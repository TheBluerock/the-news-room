{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "article.approved",
  "type": "object",
  "required": ["event_id", "trace_id", "article_id", "market", "language", "content", "moderator_id", "timestamp", "title", "excerpt", "section", "author", "tags", "slug"],
  "properties": {
    "event_id":     {"type": "string", "format": "uuid"},
    "trace_id":     {"type": "string"},
    "article_id":   {"type": "string", "format": "uuid"},
    "market":       {"type": "string", "enum": ["italy", "usa", "china"]},
    "language":     {"type": "string", "enum": ["it", "en", "zh"]},
    "content":      {"type": "string", "description": "Full article body"},
    "title":        {"type": "string", "maxLength": 200},
    "excerpt":      {"type": "string", "maxLength": 400},
    "section":      {"type": "string", "enum": ["degustazioni","cantine","itinerari","territori","abbinamenti","eventi","interviste","guida","sostenibilita"]},
    "author":       {"type": "string", "maxLength": 120},
    "tags":         {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 8},
    "slug":         {"type": "string", "maxLength": 100, "pattern": "^[a-z0-9-]+$"},
    "moderator_id": {"type": "string"},
    "quality_score": {"type": "number"},
    "timestamp":    {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
