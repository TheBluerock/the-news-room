{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "moderation.rejected",
  "type": "object",
  "required": ["event_id", "trace_id", "article_id", "market", "reason", "checks", "timestamp"],
  "properties": {
    "event_id":   {"type": "string", "format": "uuid"},
    "trace_id":   {"type": "string"},
    "article_id": {"type": "string", "format": "uuid"},
    "market":     {"type": "string", "enum": ["italy", "usa", "china"]},
    "reason":     {"type": "string"},
    "checks": {
      "type": "object",
      "properties": {
        "cultural_sensitivity": {"type": "boolean"},
        "factual_accuracy":     {"type": "boolean"},
        "quality_score":        {"type": "number"}
      }
    },
    "timestamp":  {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
