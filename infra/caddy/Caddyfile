:80 {
    # Public routes — no auth required
    @public {
        path /api/auth/login
        path /api/auth/refresh
        path /health
    }

    # Auth service (login, refresh, verify, GDPR)
    handle /api/auth/* {
        reverse_proxy http://auth:8080
    }

    handle /api/user/data {
        reverse_proxy http://auth:8080
    }

    # Admin endpoints — JWT validated + admin role enforced via auth service
    handle /api/admin/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://auth:8080
    }

    # Moderation queue and approve/reject — admin role required
    handle /api/moderation/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://moderation:8080
    }

    # Per-market agent trigger — JWT required, routed by market path segment
    handle /api/agent/italy/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://agent-italy:8080
    }

    handle /api/agent/usa/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://agent-usa:8080
    }

    handle /api/agent/china/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://agent-china:8080
    }

    # Analytics REST admin API (port 8081); gRPC on 8080 is internal-only
    handle /api/analytics/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://analytics:8081
    }

    # Editorial calendar CRUD
    handle /api/calendar/* {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://analytics:8081
    }

    # Editor corrections — learner REST HTTP
    handle /api/corrections {
        forward_auth http://auth:8080 {
            uri /internal/verify
            copy_headers X-User-ID X-User-Market X-User-Role
        }
        reverse_proxy http://learner:8088
    }

    # Health passthrough for load balancer probes
    handle /health {
        respond "ok" 200
    }

    # Public frontend (Astro static — dev server on 4321)
    handle {
        reverse_proxy http://frontend:4321
    }

    log {
        output stdout
        format json
    }
}
