---
import type { Lang } from '../lib/i18n'

interface Props {
  title: string
  description: string
  lang: Lang
  type?: 'website' | 'article'
  ogImage?: string
  article?: {
    author?: string
    publishedAt?: string
    modifiedAt?: string
    section?: string
    tags?: string[]
  }
  noindex?: boolean
}

const {
  title,
  description,
  lang,
  type = 'website',
  ogImage,
  article,
  noindex = false,
} = Astro.props

const site = (Astro.site?.toString() ?? 'https://enoica.it').replace(/\/$/, '')
const path  = Astro.url.pathname
const canonical = `${site}${path}`

// hreflang: swap /it|en|zh/ prefix
const base = path.replace(/^\/(it|en|zh)/, '')
const altIt = `${site}/it${base}`
const altEn = `${site}/en${base}`
const altZh = `${site}/zh${base}`

const locales: Record<Lang, string> = { it: 'it_IT', en: 'en_US', zh: 'zh_CN' }
const ogLocale = locales[lang]
const altLocales = Object.entries(locales).filter(([k]) => k !== lang).map(([, v]) => v)

const desc = description.slice(0, 160)

// JSON-LD
const jsonLd = type === 'article' && article
  ? {
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      headline: title,
      description: desc,
      inLanguage: lang,
      url: canonical,
      ...(ogImage && { image: [ogImage] }),
      ...(article.publishedAt && { datePublished: article.publishedAt }),
      ...(article.modifiedAt   && { dateModified: article.modifiedAt }),
      ...(article.author && { author: { '@type': 'Person', name: article.author } }),
      ...(article.tags?.length && { keywords: article.tags.join(', ') }),
      publisher: {
        '@type': 'Organization',
        name: 'ENOICA',
        url: site,
        logo: { '@type': 'ImageObject', url: `${site}/favicon.svg` },
      },
      isPartOf: { '@type': 'Periodical', name: 'ENOICA' },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ENOICA',
      url: site,
      inLanguage: lang,
      description: desc,
      publisher: { '@type': 'Organization', name: 'ENOICA', url: site },
    }
---

<title>{title}</title>

<!-- Primary -->
<meta name="description" content={desc} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="format-detection" content="telephone=no" />
<meta name="theme-color" content="#f6f3ec" />
<link rel="canonical" href={canonical} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- hreflang -->
<link rel="alternate" hreflang="it"        href={altIt} />
<link rel="alternate" hreflang="en"        href={altEn} />
<link rel="alternate" hreflang="zh"        href={altZh} />
<link rel="alternate" hreflang="x-default" href={altEn} />

<!-- Open Graph -->
<meta property="og:type"        content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url"         content={canonical} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={desc} />
<meta property="og:site_name"   content="ENOICA" />
<meta property="og:locale"      content={ogLocale} />
{altLocales.map(l => <meta property="og:locale:alternate" content={l} />)}
{ogImage && <meta property="og:image"        content={ogImage} />}
{ogImage && <meta property="og:image:width"  content="1200" />}
{ogImage && <meta property="og:image:height" content="630" />}
{ogImage && <meta property="og:image:alt"    content={title} />}

<!-- Article OG -->
{type === 'article' && article?.publishedAt && <meta property="article:published_time" content={article.publishedAt} />}
{type === 'article' && (article?.modifiedAt || article?.publishedAt) && (
  <meta property="article:modified_time" content={article?.modifiedAt ?? article?.publishedAt} />
)}
{type === 'article' && article?.section  && <meta property="article:section" content={article.section} />}
{type === 'article' && article?.tags?.map(t => <meta property="article:tag" content={t} />)}

<!-- X / Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={desc} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
{ogImage && <meta name="twitter:image:alt" content={title} />}

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 0)} />
