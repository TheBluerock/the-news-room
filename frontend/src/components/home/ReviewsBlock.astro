---
import { type Lang } from '../../lib/i18n'
import { useT } from '../../i18n'
import { MOCK_REVIEWS } from '../../data/mock'

interface Props { lang: Lang }
const { lang } = Astro.props
const T = useT(lang)
---

<section class="reviews">
  <div class="head-col">
    <h2>{T.reviews.tastingNotes}</h2>
    <p>{T.reviews.desc}</p>
  </div>
  <div class="reviews-list">
    {MOCK_REVIEWS.map(r => (
      <div class="rev">
        <span class="producer">{r.producer}</span>
        <span class="wine">{r.wine}</span>
        <span class="score">{r.score}</span>
        <span class="region">{r.region}</span>
      </div>
    ))}
  </div>
</section>
