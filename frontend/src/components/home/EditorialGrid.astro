---
import { type Lang } from '../../lib/i18n'
import { useT } from '../../i18n'
import type { Article } from '../../lib/queries'

interface Props { lang: Lang; feature: Article }
const { lang, feature } = Astro.props
const T = useT(lang)

const now = new Date()
const day = String(now.getDate()).padStart(2, '0')
const month = String(now.getMonth() + 1).padStart(2, '0')
const year = now.getFullYear()

const featDate = new Date(feature.approvedAt).toLocaleDateString(
  lang === 'zh' ? 'zh-CN' : lang === 'en' ? 'en-GB' : 'it-IT',
  { day: '2-digit', month: '2-digit', year: 'numeric' }
).replace(/\//g, ' · ')
---

<section class="editorial">
  <!-- Today block -->
  <div class="today-block">
    <span class="lbl">{T.editorial.today}</span>
    <span class="num">{day}</span>
    <span class="yr">{month} · {year}</span>
    <span class="lbl" style="margin-top:12px">{T.editorial.todayGuideLabel}</span>
    <span class="italic" style="font-size:14px;font-style:italic;line-height:1.3;color:var(--ink-soft)">{T.editorial.todayGuide}</span>
  </div>

  <!-- Utility block -->
  <div class="util-block">
    <div>
      <div class="label">{T.editorial.search}</div>
      <input placeholder={T.editorial.searchPh} />
    </div>
    <div>
      <div class="label">{T.editorial.channels}</div>
      <div class="social">
        <a href="#">Instagram ↗</a>
        <a href="#">Newsletter ↗</a>
        <a href="#">Spotify · Podcast ↗</a>
        <a href="#">RSS · Atom ↗</a>
        <a href="#">微信 · WeChat ↗</a>
      </div>
    </div>
  </div>

  <!-- Feature article -->
  <div class="feature-block">
    <div class="eyebrow">
      <span>{T.editorial.opening}</span>
      <span>{featDate}</span>
    </div>
    <div class="feat-img"></div>
    <h3>{feature.title}</h3>
    <p>{feature.excerpt}</p>
    <span class="meta">{featDate} · {feature.section.toUpperCase()} · {feature.readingTime} min</span>
  </div>

  <!-- New issue -->
  <div class="new-issue">
    <div>
      <span class="kicker">{T.editorial.issueNo}</span>
      <div class="big" style="margin-top:12px">
        {T.editorial.newGuide}
        <em>{T.editorial.wineMap}</em>
      </div>
    </div>
    <div class="greeting">{T.editorial.newGuideQuote}</div>
  </div>
</section>
