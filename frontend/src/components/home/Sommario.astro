---
import { t, type Lang } from '../../lib/i18n'
import { useT } from '../../i18n'
import { MOCK_SOMMARIO } from '../../data/mock'

interface Props { lang: Lang }
const { lang } = Astro.props
const T = useT(lang)
---

<section class="sommario">
  <h2>
    <span>{T.sommario.contents}</span>
  </h2>
  <div class="sommario-list">
    {MOCK_SOMMARIO.map(s => (
      <div class="somm-item">
        <span class="num">{s.num}</span>
        <span class="lbl">
          {t(s.label, lang)}
          {lang !== 'zh' && <span class="zh">{s.label.zh}</span>}
        </span>
        <span class="pg">p.{s.page}</span>
      </div>
    ))}
  </div>
</section>
