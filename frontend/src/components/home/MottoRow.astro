---
import { type Lang } from '../../lib/i18n'
import { useT } from '../../i18n'
import { MOCK_MOTTO } from '../../data/mock'

interface Props { lang: Lang }
const { lang } = Astro.props
const T = useT(lang)

const words = MOCK_MOTTO[lang]
---

<section class="motto-row">
  <div>
    <div class="motto-box">
      <div class="lines">
        {words.map((w, i) => <div class={i === 2 ? 'accent' : ''}>{w}</div>)}
      </div>
      <div class="small">{T.motto.small}</div>
    </div>
  </div>
  <div class="motto-side">
    <div class="visit-img"></div>
    <div class="visit-text">
      <span class="kicker">{T.motto.howToVisit}</span>
      <p><strong>{T.motto.open}: </strong>{T.motto.visitBody}</p>
    </div>
  </div>
</section>
