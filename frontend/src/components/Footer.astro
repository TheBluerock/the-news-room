---
import { SECTIONS_PRIMARY, SECTIONS_SECONDARY, t, type Lang } from '../lib/i18n'
import { useT } from '../i18n'

interface Props { lang: Lang }
const { lang } = Astro.props
const T = useT(lang)

const cols = [
  {
    h: T.footer.col.magazine,
    items: [
      { label: T.footer.links.editorial,     href: '#' },
      { label: T.footer.links.issues,        href: '#' },
      { label: T.footer.links.subscriptions, href: '#' },
      { label: T.footer.links.newsstand,     href: '#' },
    ],
  },
  {
    h: T.footer.col.sections,
    items: SECTIONS_PRIMARY.map(s => ({ label: t(s, lang), href: `/${lang}/${s.id}/` })),
  },
  {
    h: T.footer.col.services,
    items: SECTIONS_SECONDARY.map(s => ({ label: t(s, lang), href: `/${lang}/${s.id}/` })),
  },
  {
    h: T.footer.col.events,
    items: [
      { label: T.footer.links.slowWine,  href: '#' },
      { label: T.footer.links.vinitaly,  href: '#' },
      { label: T.footer.links.cernilli,  href: '#' },
      { label: T.footer.links.calendar,  href: '#' },
    ],
  },
  {
    h: T.footer.col.publisher,
    items: [
      { label: T.footer.links.about,       href: '#' },
      { label: T.footer.links.careers,     href: '#' },
      { label: T.footer.links.advertising, href: '#' },
      { label: T.footer.links.privacy,     href: '#' },
    ],
  },
]
---

<footer class="page">
  <div class="footer-top">
    <div class="display" style="font-size:28px;letter-spacing:-.03em;line-height:1">ENOICA</div>
    <div style="display:flex;gap:18px;align-items:center">
      <span class="pill red">№001 · 2026</span>
      <span class="narrow" style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)">{T.footer.tagline}</span>
    </div>
  </div>
  <div class="footer-cols">
    {cols.map(col => (
      <div>
        <h4>{col.h}</h4>
        {col.items.map(item => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    ))}
  </div>
  <div class="footer-bot">
    <span>© 2026 ENOICA · Milano</span>
    <span>{T.footer.editor}</span>
    <span>redazione@enoica.it · @enoica_mag</span>
  </div>
</footer>
