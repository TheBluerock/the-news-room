---
import { SECTIONS_PRIMARY, SECTIONS_SECONDARY, switchLang, t, type Lang } from '../lib/i18n'
import { useT } from '../i18n'

interface Props {
  lang: Lang
  activeSection?: string
  currentPath: string
}

const { lang, activeSection, currentPath } = Astro.props
const T = useT(lang)
---

<header class="page">
  <!-- Top utility bar -->
  <div class="topbar">
    <div style="display:flex;align-items:center;gap:18px">
      {T.header.nav.map(l => <a href="#">{l}</a>)}
      <div class="lang">
        {(['it','en','zh'] as const).map(l => (
          <a href={switchLang(currentPath, lang, l)} class={lang === l ? 'on' : ''}>{l.toUpperCase()}</a>
        ))}
      </div>
    </div>
  </div>

  <!-- Masthead -->
  <div class="masthead-wrap">
    <div class="masthead">
      <a href={`/${lang}/`}><h1 class="wordmark">ENOICA</h1></a>
      <div class="masthead-meta">
        {T.header.mastheadSub}
      </div>
    </div>
  </div>

  <!-- Primary nav -->
  <nav class="navgrid">
    {SECTIONS_PRIMARY.map(s => (
      <a
        href={`/${lang}/${s.id}/`}
        class={'navcell' + (activeSection === s.id ? ' active' : '')}
      >
        <span>{t(s, lang)}</span>
        <span class="zh">{s.zh}</span>
      </a>
    ))}
  </nav>

  <!-- Secondary nav -->
  <div class="secondary-nav">
    <a href={`/${lang}/`} class={!activeSection ? 'active' : ''}>{T.header.home}</a>
    {SECTIONS_SECONDARY.map(s => (
      <a href={`/${lang}/${s.id}/`} class={activeSection === s.id ? 'active' : ''}>{t(s, lang)}</a>
    ))}
    <span class="spacer"></span>
    <span class="right">{T.header.archive}</span>
  </div>
</header>
