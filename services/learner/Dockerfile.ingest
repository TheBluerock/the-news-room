FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /learner-ingest ./cmd/ingest/main.go

FROM alpine:3.20
RUN apk --no-cache add ca-certificates wget
COPY --from=builder /learner-ingest /learner-ingest
COPY config/ /config/
EXPOSE 8090
ENTRYPOINT ["/learner-ingest"]
