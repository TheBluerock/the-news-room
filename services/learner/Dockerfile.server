FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /learner-server ./cmd/server/main.go

FROM alpine:3.20
RUN apk --no-cache add ca-certificates wget
COPY --from=builder /learner-server /learner-server
EXPOSE 8080 8090
ENTRYPOINT ["/learner-server"]
